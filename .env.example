# ═══════════════════════════════════════════════════════════════════════════
# wekall-intelligence · variables de entorno
# ═══════════════════════════════════════════════════════════════════════════
#
# Copiar a `.env.local` (NO commit) y completar.
#
# Reglas:
#   - Variables con prefix VITE_ van al bundle del navegador → PÚBLICAS.
#     Nunca poner ahí API keys reales (OpenAI, service_role, etc.).
#   - Variables sin prefix VITE_ están disponibles solo en build / server.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Frontend (Vite — bundled & public) ──────────────────────────────────────

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# URL del Worker proxy (Vicky, transcribe, ingest, embed, etc.)
VITE_PROXY_URL=https://wekall-vicky-proxy.fabsaa98.workers.dev

# Base path para el bundle (CF Pages "/" · GitHub Pages "/wekall-intelligence/")
VITE_BASE_URL=/

# Presets demo (solo dev local — URL ?preset=crediminuto)
VITE_PRESET_CREDIMINUTO_PWD=
VITE_PRESET_WEKALL_PWD=

# ─── Cloudflare Pages Functions (server-side, NO frontend) ──────────────────

# Supabase admin — SERVICE key bypassa RLS, jamás exponer al cliente.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# JWT secret de Supabase Auth — necesario para requireAuth en Pages Functions.
# Dashboard Supabase → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# CORS allowlist (CSV). Si vacío, solo se aceptan los hosts DEFAULT del cors.ts.
ALLOWED_ORIGINS=https://intel.wekall.co,https://wekall-intelligence.pages.dev

# Worker proxy desde Pages Functions (en algunos endpoints).
WORKER_URL=https://wekall-vicky-proxy.fabsaa98.workers.dev
WORKER_PROXY_URL=https://wekall-vicky-proxy.fabsaa98.workers.dev

# Upstash Redis — rate limiting + jobs queue.
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Provider keys (Worker · NUNCA frontend) ────────────────────────────────
# Estas NO se configuran acá — solo via `wrangler secret put` en el Worker.
# Listadas para inventario:
#
#   OPENAI_API_KEY
#   DEEPGRAM_API_KEY
#   ANTHROPIC_API_KEY  (opcional)

# ─── Observabilidad (Sprint 2 P2-14, opcional) ──────────────────────────────

# VITE_SENTRY_DSN=
# SENTRY_DSN=
# DATADOG_API_KEY=

# ─── Compliance flags ───────────────────────────────────────────────────────

# DATA_RETENTION_DAYS=1825             # 5 años (Habeas Data Colombia)
# RIGHT_TO_FORGET_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# Validación: `npm run check-env`
# ═══════════════════════════════════════════════════════════════════════════
