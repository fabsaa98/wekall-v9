# WeKall Intelligence — Environment Variables
# Copy this file to .env.local for local development
# Never commit real secrets to git

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Cloudflare Worker proxy URL (required)
VITE_PROXY_URL=https://wekall-vicky-proxy.fabsaa98.workers.dev

# Demo presets — URL param ?preset=crediminuto (optional, dev only)
VITE_PRESET_CREDIMINUTO_PWD=
VITE_PRESET_WEKALL_PWD=
